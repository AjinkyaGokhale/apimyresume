# --- Core ---
PORT=3000
NODE_ENV=development

# Initial API key. If unset, one is generated and written to <DATA_DIR>/.apikey on first start.
# API_KEY=amr_live_xxxx

# --- Data / storage ---
DATA_DIR=./data
STORAGE_DRIVER=local

# S3 / MinIO (only when STORAGE_DRIVER=s3)
# S3_BUCKET=
# S3_ENDPOINT=
# AWS_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# --- Render / Typst ---
# Worker pool size. Defaults to max(os.cpus().length - 1, 1).
# RENDER_WORKERS=
TEMPLATES_DIR=./templates
TYPST_PACKAGE_CACHE_PATH=./data/.typst-cache
TYPST_FONT_PATHS=./fonts
RENDER_TIMEOUT_MS=30000

# --- Rate limiting ---
# Disabled by default (0 = no limit). Set to e.g. 60 to limit requests per minute per API key.
# RATE_LIMIT_PER_MINUTE=60
