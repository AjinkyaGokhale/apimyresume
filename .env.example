# --- Core ---
PORT=3000
NODE_ENV=development

# Initial API key. If unset, one is generated and written to <DATA_DIR>/.apikey on first start.
# API_KEY=amr_live_xxxx

# --- Data / storage ---
DATA_DIR=./data
STORAGE_DRIVER=local

# S3 / MinIO (only when STORAGE_DRIVER=s3)
# S3_BUCKET=
# S3_ENDPOINT=
# AWS_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# --- Render / Typst ---
# Worker pool size. Defaults to max(os.cpus().length - 1, 1).
# RENDER_WORKERS=
TEMPLATES_DIR=./templates
TYPST_PACKAGE_CACHE_PATH=./data/.typst-cache
TYPST_FONT_PATHS=./fonts
RENDER_TIMEOUT_MS=30000

# Maximum request body size in bytes (default 1 MB). Caps memory use from
# oversized uploads. Resume payloads are small JSON/YAML documents.
# MAX_BODY_BYTES=1048576

# --- Rate limiting ---
# Per-API-key request budget per minute. Default 120; set 0 to disable.
# RATE_LIMIT_PER_MINUTE=120

# Brute-force protection on owner login/setup (per client IP).
# LOGIN_RATE_LIMIT=10            # max attempts per window (0 disables)
# LOGIN_RATE_WINDOW_MS=900000    # window length in ms (default 15 min)

# --- Reverse proxy / custom domain ---
# Trust X-Forwarded-* headers: proto (for Secure cookies) and for (the real client IP).
# Enable ONLY behind a trusted reverse proxy. The bundled prod compose sets this
# automatically. Leave false when exposing the port directly.
# TRUST_PROXY=false

# Browser origins allowed to call the API cross-origin (comma-separated). The
# bundled dashboard is same-origin and needs no entry here — this is only for
# external browser clients. Defaults to localhost dev servers.
# ALLOWED_ORIGINS=https://resume.example.com
