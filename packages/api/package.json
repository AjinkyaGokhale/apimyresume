{
  "name": "apimyresume",
  "version": "0.2.0",
  "description": "APIMyResume — a polished resume for every job. Turn one profile into beautiful PDF resumes, tailored with an AI agent, n8n, or Zapier.",
  "type": "module",
  "private": true,
  "license": "MIT",
  "author": "Ajinkya Gokhale",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/db/migrate.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@hono/zod-validator": "0.4.3",
    "@myriaddreamin/typst-ts-node-compiler": "0.7.0-rc2",
    "drizzle-orm": "0.45.2",
    "hono": "4.12.23",
    "nanoid": "5.1.11",
    "p-queue": "8.1.1",
    "yaml": "2.9.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "drizzle-kit": "0.28.1",
    "typescript": "5.9.3"
  }
}
