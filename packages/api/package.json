{
  "name": "apimyresume",
  "version": "0.2.0",
  "description": "APIMyResume — a polished resume for every job. Turn one profile into beautiful PDF resumes, tailored with an AI agent, n8n, or Zapier.",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/db/migrate.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.8.0",
    "@myriaddreamin/typst-ts-node-compiler": "0.7.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.6.14",
    "nanoid": "^5.0.9",
    "p-queue": "^9.3.0",
    "yaml": "^2.6.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.1.14",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.3"
  }
}
